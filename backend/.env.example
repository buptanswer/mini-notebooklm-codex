APP_NAME=Mini-NotebookLM API
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SQLITE_PATH=storage/sqlite/mini_notebooklm.db
QDRANT_MODE=local
